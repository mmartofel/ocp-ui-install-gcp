# Wymagane - wygeneruj losowy ciąg: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=ExampleSessionSecretKeyThatShouldBeRandomAndKeptSecret

# Port serwera (domyślnie 3000)
PORT=3000

# Ścieżka do binarki openshift-install (domyślnie ./data/installer/openshift-install)
# Pobierz z: https://console.redhat.com/openshift/install/gcp/installer-provisioned
INSTALLER_PATH=./data/installer/openshift-install

# Środowisko (development lub production)
NODE_ENV=development
