<%- include('_head', { title: 'Usuwanie klastra', currentPath: '/status' }) %>

<div class="space-y-4">

  <div>
    <h1 class="text-2xl font-bold text-white">Usuwanie klastra</h1>
    <% if (install) { %>
      <p class="text-slate-400 text-sm mt-0.5">
        Klaster: <span class="text-slate-200 font-mono"><%= install.cluster_name %>.<%= install.base_domain %></span>
        &nbsp;·&nbsp; Projekt: <span class="text-slate-200 font-mono"><%= install.gcp_project %></span>
      </p>
    <% } %>
  </div>

  <!-- Status indicator -->
  <div class="bg-slate-900 border border-slate-700 rounded-xl p-5">
    <div class="flex items-center gap-2">
      <div id="statusIndicator" class="w-2.5 h-2.5 rounded-full bg-red-400 animate-pulse"></div>
      <span id="statusText" class="text-sm font-medium text-red-300">Usuwanie klastra w toku...</span>
    </div>
  </div>

  <!-- Result banner (shown after complete or failed) -->
  <div id="resultBanner" class="hidden rounded-xl px-5 py-4 border">
    <div class="flex items-center justify-between gap-4">
      <div>
        <p id="resultTitle" class="text-sm font-semibold"></p>
        <p id="resultDetail" class="text-xs mt-1 opacity-75"></p>
      </div>
      <div class="flex items-center gap-2 flex-shrink-0">
        <button id="forcePurgeBtn"
                class="hidden px-4 py-2 text-sm font-medium bg-red-950 hover:bg-red-900 border border-red-800 hover:border-red-700 text-red-300 rounded-lg transition-colors whitespace-nowrap">
          Wymuś usunięcie metadanych
        </button>
        <a href="/status"
           class="px-4 py-2 text-sm font-medium bg-slate-800 hover:bg-slate-700 border border-slate-600 hover:border-slate-500 text-slate-200 rounded-lg transition-colors whitespace-nowrap">
          Przejdź do Status →
        </a>
      </div>
    </div>
  </div>

  <!-- Terminal log viewer -->
  <div class="bg-slate-950 border border-slate-700 rounded-xl overflow-hidden">
    <div class="flex items-center gap-3 px-4 py-2.5 bg-slate-900 border-b border-slate-700">
      <div class="flex gap-1.5">
        <div class="w-3 h-3 rounded-full bg-red-500/60"></div>
        <div class="w-3 h-3 rounded-full bg-yellow-500/60"></div>
        <div class="w-3 h-3 rounded-full bg-green-500/60"></div>
      </div>
      <span class="text-xs text-slate-500 font-mono">openshift-install destroy cluster</span>
      <label class="ml-auto flex items-center gap-1.5 text-xs text-slate-500 cursor-pointer">
        <input type="checkbox" id="autoScrollToggle" checked class="accent-rh-red w-3 h-3">
        Auto-scroll
      </label>
      <span id="lineCount" class="text-xs text-slate-600 font-mono">0 linii</span>
    </div>

    <div id="logContainer" class="h-[28rem] overflow-y-auto p-4 font-mono text-xs leading-5">
      <div id="logLines"></div>
      <div id="logCursor" class="inline-block w-2 h-3.5 bg-slate-500 animate-pulse ml-0.5"></div>
    </div>
  </div>

  <div class="bg-red-950/50 border border-red-900 rounded-xl px-5 py-3 text-sm text-red-300">
    <span class="font-medium">Usuwanie może trwać 15–30 minut.</span>
    Wszystkie zasoby GCP klastra zostaną trwale usunięte.
  </div>

</div>

<!-- Force-purge confirmation modal -->
<div id="forcePurgeModal" class="hidden fixed inset-0 bg-black/70 flex items-center justify-center z-50">
  <div class="bg-slate-900 border border-red-800 rounded-xl p-6 max-w-md w-full mx-4">
    <h3 class="text-lg font-bold text-white mb-2">Wymusić usunięcie metadanych?</h3>
    <p class="text-slate-400 text-sm mb-3">
      Projekt GCP prawdopodobnie nie istnieje — klaster nie został usunięty przez instalator.
    </p>
    <div class="p-3 bg-yellow-950/40 border border-yellow-700 rounded-lg mb-4">
      <p class="text-yellow-300 text-xs font-medium mb-1">⚠ Zasoby GCP nie zostaną usunięte</p>
      <p class="text-yellow-400/80 text-xs">
        Usunięte zostaną wyłącznie metadane klastra z tego interfejsu.
        Jeśli projekt GCP nadal istnieje, usuń zasoby ręcznie lub przez konsolę GCP.
      </p>
    </div>
    <div id="forcePurgeError" class="hidden mb-3 p-3 bg-red-950/50 border border-red-800 rounded-lg text-xs text-red-300"></div>
    <div class="flex gap-3">
      <button onclick="closeForcePurgeModal()"
              class="flex-1 py-2 border border-slate-600 text-slate-300 rounded-lg text-sm hover:border-slate-400 transition-colors">
        Anuluj
      </button>
      <button id="forcePurgeConfirmBtn" onclick="confirmForcePurge()"
              class="flex-1 py-2 bg-red-700 hover:bg-red-600 text-white rounded-lg text-sm transition-colors">
        Usuń metadane
      </button>
    </div>
  </div>
</div>

<%- include('_foot') %>
<script src="/socket.io/socket.io.js"></script>
<script>
  window.INSTALL_ID = '<%= installId %>';
</script>
<script src="/js/destroy.js"></script>
</body>
</html>
