<%- include('_head', { title: 'Instalacja OpenShift', currentPath: '/install' }) %>

<div class="space-y-4">

  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-white">Instalacja OpenShift</h1>
      <% if (install) { %>
        <p class="text-slate-400 text-sm mt-0.5">
          Klaster: <span class="text-slate-200 font-mono"><%= install.cluster_name %>.<%= install.base_domain %></span>
          &nbsp;·&nbsp; Region: <span class="text-slate-200 font-mono"><%= install.gcp_region %></span>
        </p>
      <% } %>
    </div>
    <div class="flex gap-2">
      <a href="/download/logs"
         class="px-3 py-1.5 text-xs border border-slate-600 hover:border-slate-400 text-slate-400 hover:text-slate-200 rounded-lg transition-colors">
        Pobierz logi
      </a>
      <button id="abortBtn" onclick="confirmAbort()"
              class="px-3 py-1.5 text-xs border border-red-800 hover:border-rh-red text-red-400 hover:text-red-300 rounded-lg transition-colors">
        Przerwij instalację
      </button>
    </div>
  </div>

  <!-- Progress stages -->
  <div class="bg-slate-900 border border-slate-700 rounded-xl p-5">
    <div class="flex items-center gap-2 mb-3">
      <div id="statusIndicator" class="w-2.5 h-2.5 rounded-full bg-yellow-400 animate-pulse"></div>
      <span id="statusText" class="text-sm font-medium text-yellow-300">Trwa instalacja...</span>
      <span id="pctBadge" class="ml-auto text-xs text-slate-500 font-mono">0%</span>
    </div>
    <div class="w-full bg-slate-800 rounded-full h-2 mb-4">
      <div id="progressBar" class="bg-rh-red h-2 rounded-full transition-all duration-500" style="width: 0%"></div>
    </div>
    <div class="flex gap-2 flex-wrap" id="stagePills">
      <span data-stage="infrastructure"     class="stage-pill px-2.5 py-1 rounded-full text-xs border border-slate-700 text-slate-500">Zasoby GCP</span>
      <span data-stage="bootstrap"          class="stage-pill px-2.5 py-1 rounded-full text-xs border border-slate-700 text-slate-500">Bootstrap</span>
      <span data-stage="bootstrapping"      class="stage-pill px-2.5 py-1 rounded-full text-xs border border-slate-700 text-slate-500">Bootstrapping</span>
      <span data-stage="removing-bootstrap" class="stage-pill px-2.5 py-1 rounded-full text-xs border border-slate-700 text-slate-500">Usuwanie bootstrapa</span>
      <span data-stage="cluster-operators"  class="stage-pill px-2.5 py-1 rounded-full text-xs border border-slate-700 text-slate-500">Operatory</span>
      <span data-stage="console"            class="stage-pill px-2.5 py-1 rounded-full text-xs border border-slate-700 text-slate-500">Konsola</span>
      <span data-stage="complete"           class="stage-pill px-2.5 py-1 rounded-full text-xs border border-slate-700 text-slate-500">Gotowe</span>
    </div>
  </div>

  <!-- Terminal log viewer -->
  <div class="bg-slate-950 border border-slate-700 rounded-xl overflow-hidden">
    <div class="flex items-center gap-3 px-4 py-2.5 bg-slate-900 border-b border-slate-700">
      <div class="flex gap-1.5">
        <div class="w-3 h-3 rounded-full bg-red-500/60"></div>
        <div class="w-3 h-3 rounded-full bg-yellow-500/60"></div>
        <div class="w-3 h-3 rounded-full bg-green-500/60"></div>
      </div>
      <span class="text-xs text-slate-500 font-mono">.openshift_install.log</span>
      <div class="ml-auto flex items-center gap-3">
        <select id="levelFilter" onchange="filterLogs()"
                class="bg-slate-800 border border-slate-600 rounded text-xs text-slate-400 px-2 py-1">
          <option value="all">Wszystkie poziomy</option>
          <option value="info">INFO</option>
          <option value="warn">WARN</option>
          <option value="error">ERROR</option>
        </select>
        <input type="text" id="logSearch" placeholder="Szukaj w logach..." oninput="filterLogs()"
               class="bg-slate-800 border border-slate-600 rounded text-xs text-slate-400 px-2 py-1 w-40 focus:outline-none focus:border-slate-400">
        <label class="flex items-center gap-1.5 text-xs text-slate-500 cursor-pointer">
          <input type="checkbox" id="autoScrollToggle" checked class="accent-rh-red w-3 h-3">
          Auto-scroll
        </label>
        <span id="lineCount" class="text-xs text-slate-600 font-mono">0 linii</span>
      </div>
    </div>

    <div id="logContainer" class="h-[28rem] overflow-y-auto p-4 font-mono text-xs leading-5">
      <div id="logLines"></div>
      <div id="logCursor" class="inline-block w-2 h-3.5 bg-slate-500 animate-pulse ml-0.5"></div>
    </div>
  </div>

  <!-- Warning -->
  <div class="bg-yellow-950/50 border border-yellow-800 rounded-xl px-5 py-3 flex items-start gap-3 text-sm">
    <svg class="w-5 h-5 text-yellow-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
      <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
    </svg>
    <div class="text-yellow-200">
      <span class="font-medium">Instalacja trwa 30-50 minut.</span>
      Nie zamykaj tej strony. Logi są zapisywane — po ponownym otwarciu zostaną odtworzone.
    </div>
  </div>

  <!-- Abort modal -->
  <div id="abortModal" class="hidden fixed inset-0 bg-black/70 flex items-center justify-center z-50">
    <div class="bg-slate-900 border border-red-800 rounded-xl p-6 max-w-md w-full mx-4">
      <h3 class="text-lg font-bold text-white mb-2">Przerwać instalację?</h3>
      <p class="text-slate-400 text-sm mb-4">
        Zasoby GCP już utworzone <strong class="text-white">nie zostaną automatycznie usunięte</strong>.
        Musisz je usunąć ręcznie:
      </p>
      <pre class="bg-slate-800 rounded p-3 text-xs font-mono text-slate-300 mb-5 overflow-x-auto">openshift-install destroy cluster \
  --dir ./tmp/install-<%= installId || 'ID' %></pre>
      <div class="flex gap-3">
        <button onclick="closeAbortModal()"
                class="flex-1 py-2 border border-slate-600 text-slate-300 rounded-lg text-sm hover:border-slate-400 transition-colors">
          Anuluj
        </button>
        <button onclick="doAbort()"
                class="flex-1 py-2 bg-red-700 hover:bg-red-600 text-white rounded-lg text-sm transition-colors">
          Przerwij instalację
        </button>
      </div>
    </div>
  </div>

</div>

<%- include('_foot') %>
<script src="/socket.io/socket.io.js"></script>
<script>
  window.INSTALL_ID = '<%= installId %>';
  window.INSTALL_STATUS = '<%= install ? install.status : "idle" %>';
</script>
<script src="/js/install.js"></script>
</body>
</html>
